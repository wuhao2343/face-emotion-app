# Face Emotion App — environment configuration
# Copy this file to `.env` and adjust as needed.

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Compute
# "cuda" to use GPU (requires CUDA-enabled torch), "cpu" otherwise.
DEVICE=cuda
# Set to 0 to force CPU even when CUDA is available.
FORCE_CPU=0
# FP16 inference (only on CUDA, ~1.5x speedup on modern GPUs).
HALF=1

# Models
YOLO_FACE_MODEL=yolov8n-face.pt
EMOTION_MODEL_ID=trpakov/vit-face-expression

# Limits
# 4 GB accommodates most demo videos. /api/detect/video streams to a temp
# file so memory stays flat (≈ 1 MiB); /api/detect/image and
# /api/detect/frame still hold the body in RAM because cv2.imdecode needs
# bytes, so don't push MAX_UPLOAD_MB far beyond what your machine can spare
# for concurrent image requests.
MAX_UPLOAD_MB=4096
MAX_VIDEO_SIDE=1280
CAMERA_PROBE_RANGE=4
